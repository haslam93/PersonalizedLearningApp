@inject UpskillTracker.Services.TrackerService TrackerService
@inject ISnackbar Snackbar

<div class="section-shell">
    <MudPaper Class="surface-card section-intro-card certification-intro-card mb-4" Elevation="0">
        <MudStack Spacing="1">
            <MudText Typo="Typo.overline" Class="text-uppercase section-kicker">Certification goals</MudText>
            <MudText Typo="Typo.h5">Turn exam plans into dated, trackable commitments</MudText>
            <MudText Typo="Typo.body2" Class="section-summary">
                Track preparation progress, keep the next exam visible, and import current Microsoft, GitHub, and Databricks credentials without losing them in the broader plan.
            </MudText>
        </MudStack>
    </MudPaper>

    @if (isLoading)
    {
        <MudSkeleton Height="220px" Class="mb-4" />
        <MudSkeleton Height="320px" />
    }
    else
    {
        <MudGrid Spacing="2" Class="mb-4 certification-summary-grid">
            <MudItem xs="6" md="3">
                <MudPaper Class="certification-summary-card certification-summary-primary" Elevation="0">
                    <MudText Typo="Typo.h5">@ActiveGoalCount</MudText>
                    <MudText Typo="Typo.caption">Active goals</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Class="certification-summary-card certification-summary-info" Elevation="0">
                    <MudText Typo="Typo.h5">@AverageProgress%</MudText>
                    <MudText Typo="Typo.caption">Average progress</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Class="certification-summary-card certification-summary-warning" Elevation="0">
                    <MudText Typo="Typo.h5">@NextExamDate</MudText>
                    <MudText Typo="Typo.caption">Next target</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Class="certification-summary-card certification-summary-success" Elevation="0">
                    <MudText Typo="Typo.h5">@CompletedGoalCount</MudText>
                    <MudText Typo="Typo.caption">Completed</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="surface-card content-card certification-goals-card mb-4" Elevation="0">
            <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <div>
                    <MudText Typo="Typo.h6">Your certification plan</MudText>
                    <MudText Typo="Typo.body2" Class="mud-secondary-text">The nearest at-risk goal is shown first.</MudText>
                </div>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="NewCustomGoal">
                    Add custom certification
                </MudButton>
            </MudStack>

            @if (certificationGoals.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Import a credential from the catalog below or add a custom certification goal.
                </MudAlert>
            }
            else
            {
                <MudGrid Spacing="3">
                    @foreach (var goal in OrderedGoals)
                    {
                        var catalogItem = CertificationCatalog.FindForGoal(goal);
                        <MudItem xs="12" md="6">
                            <MudPaper Class="certification-goal-card" Elevation="0">
                                <MudStack Spacing="2">
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                        <div class="flex-1">
                                            <MudText Typo="Typo.h6">@goal.Title</MudText>
                                            <MudText Typo="Typo.body2" Class="mud-secondary-text">@goal.Domain • @goal.Category</MudText>
                                        </div>
                                        <MudChip T="string" Variant="Variant.Filled" Color="@GetAttentionColor(goal)" Size="Size.Small">
                                            @TrainingPlanPrioritizer.GetAttentionLabel(goal, today)
                                        </MudChip>
                                    </MudStack>

                                    <MudText Typo="Typo.body2">@goal.Description</MudText>
                                    <MudProgressLinear Value="@goal.ProgressPercent" Rounded="true" Color="@GetAttentionColor(goal)" Size="Size.Large" />
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.caption" Class="mud-secondary-text">@goal.ProgressPercent% prepared • target @goal.TargetDate.ToString("MMM d, yyyy")</MudText>
                                        <MudChip T="string" Variant="Variant.Outlined" Color="@GetStatusColor(goal.Status)" Size="Size.Small">@FormatStatus(goal.Status)</MudChip>
                                    </MudStack>

                                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                        @if (catalogItem is not null)
                                        {
                                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@catalogItem.CredentialUrl" Target="_blank" EndIcon="@Icons.Material.Filled.OpenInNew">
                                                Credential
                                            </MudButton>
                                            @if (!string.IsNullOrWhiteSpace(catalogItem.StudyGuideUrl))
                                            {
                                                <MudButton Variant="Variant.Text" Color="Color.Secondary" Href="@catalogItem.StudyGuideUrl" Target="_blank" EndIcon="@Icons.Material.Filled.MenuBook">
                                                    Study guide
                                                </MudButton>
                                            }
                                        }
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => BeginEdit(goal))">
                                            Update progress
                                        </MudButton>
                                        @if (goal.Status != UpskillTracker.Models.TrackerStatus.Completed)
                                        {
                                            <MudButton Variant="Variant.Filled"
                                                       Color="Color.Success"
                                                       StartIcon="@Icons.Material.Filled.CheckCircle"
                                                       OnClick="@(() => CompleteGoalAsync(goal))">
                                                Mark complete
                                            </MudButton>
                                        }
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudPaper>

        @if (editingGoal is not null)
        {
            <MudPaper Class="surface-card editor-card certification-editor-card mb-4" Elevation="0">
                <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">@(editingGoal.Id == 0 ? "Add certification goal" : $"Update {editingGoal.Category}")</MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelEdit">Close</MudButton>
                </MudStack>

                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="editingGoal.Title" Label="Certification name" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="editingGoal.Domain" Label="Provider" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="editingGoal.Category" Label="Exam code" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker Label="Target date" Date="@editingTargetDate" DateChanged="OnTargetDateChanged" Variant="Variant.Outlined" Editable="true" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="UpskillTracker.Models.TrackerStatus" @bind-Value="editingGoal.Status" Label="Status" Variant="Variant.Outlined">
                            @foreach (var status in Enum.GetValues<UpskillTracker.Models.TrackerStatus>())
                            {
                                <MudSelectItem T="UpskillTracker.Models.TrackerStatus" Value="@status">@status</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudNumericField T="decimal" @bind-Value="editingGoal.EstimatedHours" Label="Preparation hours" Variant="Variant.Outlined" Min="0.5m" Max="40m" Step="0.5m" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="editingGoal.Description" Label="Credential scope" Variant="Variant.Outlined" Lines="2" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSlider T="int" @bind-Value="editingGoal.ProgressPercent" Min="0" Max="100" Step="5" Color="Color.Primary" />
                        <MudText Typo="Typo.caption" Class="mud-secondary-text">Preparation progress: @editingGoal.ProgressPercent%</MudText>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="editingGoal.Notes" Label="Preparation plan and notes" Variant="Variant.Outlined" Lines="4" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="editingGoal.Evidence" Label="Practice scores and evidence" Variant="Variant.Outlined" Lines="4" />
                    </MudItem>
                </MudGrid>

                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveGoalAsync">Save goal</MudButton>
                    @if (editingGoal.Id != 0)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="DeleteGoalAsync">Delete goal</MudButton>
                    }
                </MudStack>
            </MudPaper>
        }

        <MudPaper Class="surface-card content-card certification-catalog-card" Elevation="0">
            <MudStack Spacing="1" Class="mb-4">
                <MudText Typo="Typo.h6">Import another certification</MudText>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">
                    Importing adds a dated certification goal to PostgreSQL and its official credential page to Resources.
                </MudText>
            </MudStack>

            <div class="certification-provider-filters mb-4" role="group" aria-label="Filter certification catalog by provider">
                @foreach (var provider in CatalogProviders)
                {
                    <MudButton Color="Color.Primary"
                               Variant="@(selectedProvider == provider ? Variant.Filled : Variant.Outlined)"
                               aria-pressed="@(selectedProvider == provider ? "true" : "false")"
                               OnClick="@(() => selectedProvider = provider)">
                        @provider
                    </MudButton>
                }
            </div>

            <MudGrid Spacing="3">
                @foreach (var certification in FilteredCatalog)
                {
                    var imported = IsImported(certification);
                    <MudItem xs="12" md="6">
                        <MudPaper Class="certification-catalog-entry" Elevation="0">
                            <MudStack Spacing="2">
                                <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                    <div class="flex-1">
                                        <MudText Typo="Typo.subtitle1">@certification.Title</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-secondary-text">@certification.Provider • @certification.Code</MudText>
                                    </div>
                                    @if (certification.IsRecommended)
                                    {
                                        <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">Recommended</MudChip>
                                    }
                                </MudStack>
                                <MudText Typo="Typo.body2">@certification.Description</MudText>
                                <MudText Typo="Typo.caption" Class="mud-secondary-text">
                                    Suggested target @certification.RecommendedTargetDate.ToString("MMM d, yyyy") • @certification.EstimatedHours hours
                                </MudText>
                                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@certification.CredentialUrl" Target="_blank" EndIcon="@Icons.Material.Filled.OpenInNew">
                                        View credential
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@imported" OnClick="@(() => ImportCertificationAsync(certification))">
                                        @(imported ? "Imported" : "Import goal")
                                    </MudButton>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>
    }
</div>

@code {
    private readonly DateTime today = DateTime.UtcNow.Date;
    private static readonly string[] CatalogProviders = ["All", "Microsoft", "GitHub", "Databricks"];
    private List<UpskillTracker.Models.TrainingItem> certificationGoals = [];
    private UpskillTracker.Models.TrainingItem? editingGoal;
    private DateTime? editingTargetDate;
    private string selectedProvider = "All";
    private bool isLoading = true;

    private IEnumerable<UpskillTracker.Models.TrainingItem> OrderedGoals
        => TrainingPlanPrioritizer.OrderForFocus(certificationGoals, today);

    private IEnumerable<UpskillTracker.Models.CertificationCatalogItem> FilteredCatalog
        => CertificationCatalog.Items
            .Where(item => selectedProvider == "All" || item.Provider.Equals(selectedProvider, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(item => item.IsRecommended)
            .ThenBy(item => item.RecommendedTargetDate);

    private int ActiveGoalCount => certificationGoals.Count(goal => goal.Status != UpskillTracker.Models.TrackerStatus.Completed);

    private int CompletedGoalCount => certificationGoals.Count(goal => goal.Status == UpskillTracker.Models.TrackerStatus.Completed);

    private int AverageProgress => certificationGoals.Count == 0
        ? 0
        : (int)Math.Round(certificationGoals.Average(goal => goal.ProgressPercent));

    private string NextExamDate => certificationGoals
        .Where(goal => goal.Status != UpskillTracker.Models.TrackerStatus.Completed)
        .OrderBy(goal => goal.TargetDate)
        .Select(goal => goal.TargetDate.ToString("MMM d"))
        .FirstOrDefault() ?? "Not set";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        isLoading = false;
    }

    private async Task LoadAsync()
    {
        certificationGoals = (await TrackerService.GetTrainingItemsAsync())
            .Where(item => item.Type == UpskillTracker.Models.TrainingItemType.Certification)
            .ToList();
    }

    private bool IsImported(UpskillTracker.Models.CertificationCatalogItem certification)
        => certificationGoals.Any(goal =>
            goal.Title.Equals(certification.Title, StringComparison.OrdinalIgnoreCase) ||
            (!string.IsNullOrWhiteSpace(goal.Category) && goal.Category.Equals(certification.Code, StringComparison.OrdinalIgnoreCase)));

    private async Task ImportCertificationAsync(UpskillTracker.Models.CertificationCatalogItem certification)
    {
        try
        {
            var imported = await TrackerService.ImportCertificationAsync(certification);
            Snackbar.Add(imported ? $"{certification.Code} added to your certification plan." : $"{certification.Code} is already in your plan.", imported ? Severity.Success : Severity.Info);
            await LoadAsync();
        }
        catch (UpskillTracker.Services.TrackerStorageUnavailableException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private void BeginEdit(UpskillTracker.Models.TrainingItem goal)
    {
        editingGoal = goal.Clone();
        editingTargetDate = editingGoal.TargetDate;
    }

    private void NewCustomGoal()
    {
        editingGoal = new UpskillTracker.Models.TrainingItem
        {
            Domain = "Microsoft",
            Type = UpskillTracker.Models.TrainingItemType.Certification,
            Lane = UpskillTracker.Models.LearningLane.Core,
            Status = UpskillTracker.Models.TrackerStatus.NotStarted,
            TargetDate = today.AddDays(90),
            EstimatedHours = 20,
            Priority = 3
        };
        editingTargetDate = editingGoal.TargetDate;
    }

    private void OnTargetDateChanged(DateTime? value)
    {
        editingTargetDate = value;
        if (editingGoal is not null)
        {
            editingGoal.TargetDate = value ?? editingGoal.TargetDate;
        }
    }

    private async Task SaveGoalAsync()
    {
        if (editingGoal is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(editingGoal.Title) || string.IsNullOrWhiteSpace(editingGoal.Domain))
        {
            Snackbar.Add("Certification name and provider are required.", Severity.Warning);
            return;
        }

        editingGoal.Type = UpskillTracker.Models.TrainingItemType.Certification;
        editingGoal.TargetDate = editingTargetDate ?? editingGoal.TargetDate;

        if (editingGoal.ProgressPercent >= 100)
        {
            editingGoal.ProgressPercent = 100;
            editingGoal.Status = UpskillTracker.Models.TrackerStatus.Completed;
        }
        else if (editingGoal.ProgressPercent > 0 && editingGoal.Status == UpskillTracker.Models.TrackerStatus.NotStarted)
        {
            editingGoal.Status = UpskillTracker.Models.TrackerStatus.InProgress;
        }

        try
        {
            await TrackerService.SaveTrainingItemAsync(editingGoal);
            Snackbar.Add("Certification goal saved.", Severity.Success);
            editingGoal = null;
            editingTargetDate = null;
            await LoadAsync();
        }
        catch (UpskillTracker.Services.TrackerStorageUnavailableException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private async Task CompleteGoalAsync(UpskillTracker.Models.TrainingItem goal)
    {
        var completedGoal = goal.Clone();
        completedGoal.ProgressPercent = 100;
        completedGoal.Status = UpskillTracker.Models.TrackerStatus.Completed;

        try
        {
            await TrackerService.SaveTrainingItemAsync(completedGoal);
            Snackbar.Add($"{goal.Title} marked complete.", Severity.Success);
            await LoadAsync();
        }
        catch (UpskillTracker.Services.TrackerStorageUnavailableException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private async Task DeleteGoalAsync()
    {
        if (editingGoal is null || editingGoal.Id == 0)
        {
            return;
        }

        try
        {
            await TrackerService.DeleteTrainingItemAsync(editingGoal.Id);
            Snackbar.Add("Certification goal deleted.", Severity.Info);
            editingGoal = null;
            editingTargetDate = null;
            await LoadAsync();
        }
        catch (UpskillTracker.Services.TrackerStorageUnavailableException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private void CancelEdit()
    {
        editingGoal = null;
        editingTargetDate = null;
    }

    private Color GetAttentionColor(UpskillTracker.Models.TrainingItem goal)
        => TrainingPlanPrioritizer.GetAttentionLevel(goal, today) switch
        {
            UpskillTracker.Models.PlanAttentionLevel.Overdue => Color.Error,
            UpskillTracker.Models.PlanAttentionLevel.DueSoon => Color.Warning,
            UpskillTracker.Models.PlanAttentionLevel.InProgress => Color.Info,
            UpskillTracker.Models.PlanAttentionLevel.Completed => Color.Success,
            _ => Color.Primary
        };

    private static Color GetStatusColor(UpskillTracker.Models.TrackerStatus status) => status switch
    {
        UpskillTracker.Models.TrackerStatus.Completed => Color.Success,
        UpskillTracker.Models.TrackerStatus.InProgress => Color.Info,
        UpskillTracker.Models.TrackerStatus.Blocked => Color.Error,
        _ => Color.Default
    };

    private static string FormatStatus(UpskillTracker.Models.TrackerStatus status) => status switch
    {
        UpskillTracker.Models.TrackerStatus.NotStarted => "Not started",
        UpskillTracker.Models.TrackerStatus.InProgress => "In progress",
        _ => status.ToString()
    };
}
