@inject UpskillTracker.Services.TrackerService TrackerService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<div class="section-shell">
    <MudPaper Class="surface-card section-intro-card planner-intro-card mb-4" Elevation="0">
        <MudStack Spacing="1">
            <MudText Typo="Typo.overline" Class="text-uppercase section-kicker">Learning planner</MudText>
            <MudText Typo="Typo.h5">Shape the work behind your upskilling plan</MudText>
            <MudText Typo="Typo.body2" Class="section-summary">
                Filter active commitments, jump to supporting resources, and keep each item current without leaving the tab.
            </MudText>
        </MudStack>
    </MudPaper>

<MudGrid Class="section-grid">
    <MudItem xs="12">
        <MudPaper Class="surface-card content-card planner-table-card mb-4" Elevation="0">
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-4 reminder-alert">
                Work top to bottom in the focus view. Overdue and near-term core commitments come first; nice-to-have work stays visible without competing with required progress.
            </MudAlert>

            <MudGrid Spacing="2" Class="mb-4 planner-focus-summary">
                <MudItem xs="6" md="3">
                    <button type="button" class="planner-focus-stat planner-focus-button planner-focus-stat-risk" @onclick="@(() => SetFocusFilter("At risk"))">
                        <MudText Typo="Typo.h5">@AtRiskCount</MudText>
                        <MudText Typo="Typo.caption">At risk</MudText>
                        <MudText Typo="Typo.caption" Class="planner-focus-action">Show items</MudText>
                    </button>
                </MudItem>
                <MudItem xs="6" md="3">
                    <button type="button" class="planner-focus-stat planner-focus-button planner-focus-stat-core" @onclick="@(() => SetFocusFilter("Core commitments"))">
                        <MudText Typo="Typo.h5">@CoreCommitmentCount</MudText>
                        <MudText Typo="Typo.caption">Core remaining</MudText>
                        <MudText Typo="Typo.caption" Class="planner-focus-action">Show commitments</MudText>
                    </button>
                </MudItem>
                <MudItem xs="6" md="3">
                    <button type="button" class="planner-focus-stat planner-focus-button planner-focus-stat-active" @onclick="@(() => SetFocusFilter("In progress"))">
                        <MudText Typo="Typo.h5">@InProgressCount</MudText>
                        <MudText Typo="Typo.caption">In progress</MudText>
                        <MudText Typo="Typo.caption" Class="planner-focus-action">Continue learning</MudText>
                    </button>
                </MudItem>
                <MudItem xs="6" md="3">
                    <button type="button" class="planner-focus-stat planner-focus-button planner-focus-stat-optional" @onclick="@(() => SetFocusFilter("Nice to have"))">
                        <MudText Typo="Typo.h5">@NiceToHaveCount</MudText>
                        <MudText Typo="Typo.caption">Nice to have</MudText>
                        <MudText Typo="Typo.caption" Class="planner-focus-action">Review optional work</MudText>
                    </button>
                </MudItem>
            </MudGrid>

            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" Class="mb-4">
                <MudTextField @bind-Value="searchText" Placeholder="Search training items" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="flex-1" />
                <MudSelect T="string" @bind-Value="selectedFocusFilter" Label="Focus" Variant="Variant.Outlined">
                    @foreach (var option in FocusFilterOptions)
                    {
                        <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="UpskillTracker.Models.TrackerStatus?" @bind-Value="selectedStatus" Label="Status" Variant="Variant.Outlined" Clearable="true">
                    @foreach (var status in Enum.GetValues<UpskillTracker.Models.TrackerStatus>())
                    {
                        <MudSelectItem T="UpskillTracker.Models.TrackerStatus?" Value="@status">@status</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="UpskillTracker.Models.LearningLane?" @bind-Value="selectedLane" Label="Lane" Variant="Variant.Outlined" Clearable="true">
                    @foreach (var lane in Enum.GetValues<UpskillTracker.Models.LearningLane>())
                    {
                        <MudSelectItem T="UpskillTracker.Models.LearningLane?" Value="@lane">@lane</MudSelectItem>
                    }
                </MudSelect>
            </MudStack>

            <MudTable Items="FilteredItems" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm" RowClassFunc="GetRowClass">
                <HeaderContent>
                    <MudTh>Item</MudTh>
                    <MudTh>Domain</MudTh>
                    <MudTh>Due</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Progress</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Item">
                        <MudText Typo="Typo.subtitle2">@context.Title</MudText>
                        <MudText Typo="Typo.caption" Class="mud-secondary-text">@context.Type • @TrainingPlanPrioritizer.GetCommitmentLabel(context)</MudText>
                        @if (!string.IsNullOrWhiteSpace(context.Description))
                        {
                            <MudText Typo="Typo.body2" Class="mt-1 mud-secondary-text">@context.Description</MudText>
                        }
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-2">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@GetAttentionColor(context)">
                                @TrainingPlanPrioritizer.GetAttentionLabel(context, today)
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetCommitmentColor(context)">
                                @TrainingPlanPrioritizer.GetCommitmentLabel(context)
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">
                                Priority @context.Priority
                            </MudChip>
                        </MudStack>

                        @{ var suggestedResources = GetSuggestedResources(context); }
                        @if (suggestedResources.Count > 0)
                        {
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-2">
                                @foreach (var resource in suggestedResources)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OpenResourceAsync(resource))" EndIcon="@Icons.Material.Filled.OpenInNew">
                                        @resource.Title
                                    </MudButton>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Class="mud-secondary-text d-block mt-2">No matching resource yet. Add one in Resources and it will appear here.</MudText>
                        }
                        <MudStack Spacing="0" Class="mt-2">
                            <MudText Typo="Typo.caption" Class="mud-secondary-text">Last status change @FormatAbsolute(context.LastStatusChangedUtc)</MudText>
                            @if (context.CompletedUtc.HasValue)
                            {
                                <MudText Typo="Typo.caption" Class="mud-secondary-text">Completed @FormatAbsolute(context.CompletedUtc.Value)</MudText>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Domain">@context.Domain</MudTd>
                    <MudTd DataLabel="Due">
                        <MudText Typo="Typo.body2">@context.TargetDate.ToString("MMM d")</MudText>
                        <MudText Typo="Typo.caption" Class="@GetDueTextClass(context)">@TrainingPlanPrioritizer.GetAttentionLabel(context, today)</MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Variant="Variant.Filled" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Progress">
                        <MudProgressLinear Value="@context.ProgressPercent" Rounded="true" Color="@GetAttentionColor(context)" />
                        <MudText Typo="Typo.caption" Class="mud-secondary-text">@context.ProgressPercent%</MudText>
                    </MudTd>
                    <MudTd Style="text-align: right;">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => BeginEditAsync(context))">Edit</MudButton>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body2">No items match the current filters.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <div id="planner-editor"></div>
        <MudPaper Class="surface-card content-card editor-card mb-4" Elevation="0">
            <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">@(editingItem.Id == 0 ? "Add training item" : "Edit training item")</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="CreateNew">New item</MudButton>
            </MudStack>

            <MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="editingItem.Title" Label="Title" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="editingItem.Domain" Label="Domain" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="editingItem.Category" Label="Category" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Target date" Date="@targetDate" DateChanged="OnTargetDateChanged" Variant="Variant.Outlined" Editable="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="editingItem.Description" Label="Description" Variant="Variant.Outlined" Lines="3" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="UpskillTracker.Models.TrackerStatus" @bind-Value="editingItem.Status" Label="Status" Variant="Variant.Outlined">
                        @foreach (var status in Enum.GetValues<UpskillTracker.Models.TrackerStatus>())
                        {
                            <MudSelectItem T="UpskillTracker.Models.TrackerStatus" Value="@status">@status</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="UpskillTracker.Models.LearningLane" @bind-Value="editingItem.Lane" Label="Lane" Variant="Variant.Outlined">
                        @foreach (var lane in Enum.GetValues<UpskillTracker.Models.LearningLane>())
                        {
                            <MudSelectItem T="UpskillTracker.Models.LearningLane" Value="@lane">@GetLaneLabel(lane)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="UpskillTracker.Models.TrainingItemType" @bind-Value="editingItem.Type" Label="Type" Variant="Variant.Outlined">
                        @foreach (var itemType in Enum.GetValues<UpskillTracker.Models.TrainingItemType>())
                        {
                            <MudSelectItem T="UpskillTracker.Models.TrainingItemType" Value="@itemType">@itemType</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="decimal" @bind-Value="editingItem.EstimatedHours" Label="Hours" Variant="Variant.Outlined" Min="0.5m" Max="40m" Step="0.5m" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int" @bind-Value="editingItem.Priority" Label="Priority (1 optional, 5 critical)" Variant="Variant.Outlined" Min="1" Max="5" Step="1" />
                </MudItem>
                <MudItem xs="12" sm="4" Class="d-flex align-center">
                    <MudCheckBox @bind-Value="editingItem.ProjectDriven" Label="Project-driven" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12">
                    <MudSlider T="int" @bind-Value="editingItem.ProgressPercent" Min="0" Max="100" Step="5" Color="Color.Primary" />
                    <MudText Typo="Typo.caption" Class="mud-secondary-text">Progress: @editingItem.ProgressPercent%</MudText>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="editingItem.Notes" Label="Notes" Variant="Variant.Outlined" Lines="4" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="editingItem.Evidence" Label="Evidence or next proof point" Variant="Variant.Outlined" Lines="4" />
                </MudItem>
            </MudGrid>

            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" Class="mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">Save item</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="CreateNew">Reset</MudButton>
                @if (editingItem.Id != 0)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="DeleteAsync">Delete</MudButton>
                }
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>
</div>

@code {
    [Parameter]
    public UpskillTracker.Models.PlanNavigationRequest NavigationRequest { get; set; } = new("Do next");

    [Parameter]
    public int NavigationRequestId { get; set; }

    private List<UpskillTracker.Models.TrainingItem> items = [];
    private List<UpskillTracker.Models.ResourceEntry> resources = [];
    private UpskillTracker.Models.TrainingItem editingItem = CreateEmptyItem();
    private string searchText = string.Empty;
    private UpskillTracker.Models.TrackerStatus? selectedStatus;
    private UpskillTracker.Models.LearningLane? selectedLane;
    private string selectedFocusFilter = "Do next";
    private DateTime? targetDate;
    private readonly DateTime today = DateTime.UtcNow.Date;
    private static readonly string[] FocusFilterOptions = ["Do next", "All work", "At risk", "Due soon", "In progress", "Core commitments", "Nice to have", "Certifications"];
    private int appliedNavigationRequestId = -1;
    private bool hasLoaded;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        hasLoaded = true;
        ApplyNavigationRequest();
    }

    protected override void OnParametersSet()
    {
        if (hasLoaded)
        {
            ApplyNavigationRequest();
        }
    }

    private IEnumerable<UpskillTracker.Models.TrainingItem> FilteredItems => TrainingPlanPrioritizer.OrderForFocus(
        items.Where(item =>
            (string.IsNullOrWhiteSpace(searchText) || item.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) || item.Domain.Contains(searchText, StringComparison.OrdinalIgnoreCase) || item.Category.Contains(searchText, StringComparison.OrdinalIgnoreCase)) &&
            (!selectedStatus.HasValue || item.Status == selectedStatus.Value) &&
            (!selectedLane.HasValue || item.Lane == selectedLane.Value) &&
            MatchesFocusFilter(item)),
        today);

    private int AtRiskCount => items.Count(item => TrainingPlanPrioritizer.IsAtRisk(item, today));

    private int CoreCommitmentCount => items.Count(item => item.Status != UpskillTracker.Models.TrackerStatus.Completed && !TrainingPlanPrioritizer.IsNiceToHave(item));

    private int InProgressCount => items.Count(item => item.Status == UpskillTracker.Models.TrackerStatus.InProgress);

    private int NiceToHaveCount => items.Count(item => item.Status != UpskillTracker.Models.TrackerStatus.Completed && TrainingPlanPrioritizer.IsNiceToHave(item));

    private async Task LoadAsync()
    {
        items = await TrackerService.GetTrainingItemsAsync();
        resources = await TrackerService.GetResourcesAsync();
        if (editingItem.Id != 0)
        {
            var refreshed = items.FirstOrDefault(item => item.Id == editingItem.Id);
            if (refreshed is not null)
            {
                BeginEdit(refreshed);
            }
        }
    }

    private IReadOnlyList<UpskillTracker.Models.ResourceEntry> GetSuggestedResources(UpskillTracker.Models.TrainingItem item)
        => TaskResourceMatcher.GetMatches(item, resources, 3);

    private void BeginEdit(UpskillTracker.Models.TrainingItem item)
    {
        editingItem = item.Clone();
        targetDate = editingItem.TargetDate;
    }

    private async Task BeginEditAsync(UpskillTracker.Models.TrainingItem item)
    {
        BeginEdit(item);
        try
        {
            await JSRuntime.InvokeVoidAsync("scrollToElement", "planner-editor");
        }
        catch (JSException)
        {
            // Scrolling is a best-effort enhancement; ignore if unavailable.
        }
    }

    private void CreateNew()
    {
        editingItem = CreateEmptyItem();
        targetDate = editingItem.TargetDate;
    }

    private void OnTargetDateChanged(DateTime? value)
    {
        targetDate = value;
        editingItem.TargetDate = value ?? DateTime.UtcNow.Date;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(editingItem.Title) || string.IsNullOrWhiteSpace(editingItem.Domain))
        {
            Snackbar.Add("Title and domain are required.", Severity.Warning);
            return;
        }

        editingItem.TargetDate = targetDate ?? editingItem.TargetDate;
        try
        {
            await TrackerService.SaveTrainingItemAsync(editingItem);
            Snackbar.Add("Training item saved.", Severity.Success);
            await LoadAsync();
            CreateNew();
        }
        catch (UpskillTracker.Services.TrackerStorageUnavailableException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private async Task DeleteAsync()
    {
        if (editingItem.Id == 0)
        {
            return;
        }

        try
        {
            await TrackerService.DeleteTrainingItemAsync(editingItem.Id);
            Snackbar.Add("Training item deleted.", Severity.Info);
            await LoadAsync();
            CreateNew();
        }
        catch (UpskillTracker.Services.TrackerStorageUnavailableException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private async Task OpenResourceAsync(UpskillTracker.Models.ResourceEntry resource)
    {
        try
        {
            await TrackerService.TouchResourceOpenedAsync(resource.Id);
        }
        catch (UpskillTracker.Services.TrackerStorageUnavailableException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }

        await JSRuntime.InvokeVoidAsync("open", resource.Url, "_blank", "noopener,noreferrer");
    }

    private bool MatchesFocusFilter(UpskillTracker.Models.TrainingItem item) => selectedFocusFilter switch
    {
        "Do next" => item.Status != UpskillTracker.Models.TrackerStatus.Completed && !TrainingPlanPrioritizer.IsNiceToHave(item),
        "At risk" => TrainingPlanPrioritizer.IsAtRisk(item, today),
        "Due soon" => item.Status != UpskillTracker.Models.TrackerStatus.Completed &&
            TrainingPlanPrioritizer.GetAttentionLevel(item, today) == UpskillTracker.Models.PlanAttentionLevel.DueSoon,
        "In progress" => item.Status == UpskillTracker.Models.TrackerStatus.InProgress,
        "Core commitments" => item.Status != UpskillTracker.Models.TrackerStatus.Completed && !TrainingPlanPrioritizer.IsNiceToHave(item),
        "Nice to have" => item.Status != UpskillTracker.Models.TrackerStatus.Completed && TrainingPlanPrioritizer.IsNiceToHave(item),
        "Certifications" => item.Type == UpskillTracker.Models.TrainingItemType.Certification,
        _ => true
    };

    private void SetFocusFilter(string filter)
    {
        selectedFocusFilter = filter;
        selectedStatus = null;
        selectedLane = null;
        searchText = string.Empty;
    }

    private void ApplyNavigationRequest()
    {
        if (appliedNavigationRequestId == NavigationRequestId)
        {
            return;
        }

        appliedNavigationRequestId = NavigationRequestId;
        selectedStatus = null;
        selectedLane = null;

        if (NavigationRequest.TrainingItemId.HasValue)
        {
            var item = items.FirstOrDefault(candidate => candidate.Id == NavigationRequest.TrainingItemId.Value);
            selectedFocusFilter = "All work";
            searchText = item?.Title ?? string.Empty;
            return;
        }

        selectedFocusFilter = FocusFilterOptions.Contains(NavigationRequest.FocusFilter, StringComparer.OrdinalIgnoreCase)
            ? NavigationRequest.FocusFilter
            : "Do next";
        searchText = string.Empty;
    }

    private string GetRowClass(UpskillTracker.Models.TrainingItem item, int _) => item.Status switch
    {
        UpskillTracker.Models.TrackerStatus.Completed => "row-completed",
        UpskillTracker.Models.TrackerStatus.Blocked => "row-blocked",
        _ => TrainingPlanPrioritizer.GetAttentionLevel(item, today) switch
        {
            UpskillTracker.Models.PlanAttentionLevel.Overdue => "row-overdue",
            UpskillTracker.Models.PlanAttentionLevel.DueSoon => "row-due-soon",
            UpskillTracker.Models.PlanAttentionLevel.NiceToHave => "row-nice-to-have",
            _ => string.Empty
        }
    };

    private static Color GetStatusColor(UpskillTracker.Models.TrackerStatus status) => status switch
    {
        UpskillTracker.Models.TrackerStatus.Completed => Color.Success,
        UpskillTracker.Models.TrackerStatus.InProgress => Color.Info,
        UpskillTracker.Models.TrackerStatus.Blocked => Color.Error,
        _ => Color.Default
    };

    private Color GetAttentionColor(UpskillTracker.Models.TrainingItem item)
        => TrainingPlanPrioritizer.GetAttentionLevel(item, today) switch
        {
            UpskillTracker.Models.PlanAttentionLevel.Overdue => Color.Error,
            UpskillTracker.Models.PlanAttentionLevel.DueSoon => Color.Warning,
            UpskillTracker.Models.PlanAttentionLevel.InProgress => Color.Info,
            UpskillTracker.Models.PlanAttentionLevel.NiceToHave => Color.Default,
            UpskillTracker.Models.PlanAttentionLevel.Completed => Color.Success,
            _ => Color.Primary
        };

    private static Color GetCommitmentColor(UpskillTracker.Models.TrainingItem item) => item.Lane switch
    {
        UpskillTracker.Models.LearningLane.RapidRamp => Color.Warning,
        UpskillTracker.Models.LearningLane.Stretch when !item.ProjectDriven => Color.Default,
        _ => Color.Primary
    };

    private string GetDueTextClass(UpskillTracker.Models.TrainingItem item)
        => TrainingPlanPrioritizer.GetAttentionLevel(item, today) switch
        {
            UpskillTracker.Models.PlanAttentionLevel.Overdue => "planner-due planner-due-overdue",
            UpskillTracker.Models.PlanAttentionLevel.DueSoon => "planner-due planner-due-soon",
            _ => "planner-due mud-secondary-text"
        };

    private static string GetLaneLabel(UpskillTracker.Models.LearningLane lane) => lane switch
    {
        UpskillTracker.Models.LearningLane.Core => "Core commitment",
        UpskillTracker.Models.LearningLane.Stretch => "Nice to have",
        UpskillTracker.Models.LearningLane.RapidRamp => "Rapid ramp",
        _ => lane.ToString()
    };

    private static UpskillTracker.Models.TrainingItem CreateEmptyItem()
    {
        return new UpskillTracker.Models.TrainingItem
        {
            TargetDate = DateTime.UtcNow.Date.AddDays(7),
            Priority = 3,
            EstimatedHours = 2,
            Lane = UpskillTracker.Models.LearningLane.Core,
            Type = UpskillTracker.Models.TrainingItemType.Learning,
            Status = UpskillTracker.Models.TrackerStatus.NotStarted
        };
    }

    private static string FormatAbsolute(DateTime? timestamp)
        => timestamp.HasValue
            ? timestamp.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
            : "Not tracked yet";
}
