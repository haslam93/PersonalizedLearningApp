@inject UpskillTracker.Services.TrackerService TrackerService
@inject UpskillTracker.Services.AnnouncementFeedService AnnouncementFeedService
@inject ISnackbar Snackbar

@if (isLoading)
{
    <MudSkeleton Height="280px" Class="mb-4" />
    <MudSkeleton Height="280px" />
}
else if (snapshot is not null)
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="hero-card dashboard-summary-card mb-4" Elevation="0">
                <MudStack Spacing="2">
                    <div>
                        <MudText Typo="Typo.overline" Class="text-uppercase overview-kicker">Progress snapshot</MudText>
                        <MudText Typo="Typo.h4" Class="mb-2">@GetDashboardHeadline()</MudText>
                        <MudText Typo="Typo.body1" Class="overview-summary">@GetDashboardSummary()</MudText>
                    </div>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Flag">@snapshot.FocusItems.Count active focus items</MudChip>
                        <MudChip T="string" Color="Color.Secondary" Variant="Variant.Filled" Icon="@Icons.Material.Filled.LibraryBooks">@snapshot.PinnedResources.Count pinned resources</MudChip>
                        <MudChip T="string" Color="Color.Info" Variant="Variant.Filled" Icon="@Icons.Material.Filled.StickyNote2">@snapshot.RecentNotes.Count recent notes</MudChip>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="surface-card mb-4 stat-card" Elevation="0">
                <MudText Typo="Typo.subtitle2" Class="mud-secondary-text">Completion rate</MudText>
                <MudText Typo="Typo.h3" Class="mb-3">@snapshot.CompletionRate%</MudText>
                <MudProgressLinear Value="@completionRate" Rounded="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Class="mt-3 mud-secondary-text">
                    @snapshot.CompletedItems of @snapshot.TotalItems planned items are done.
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mb-4">
        <MudItem xs="6" md="3">
            <MudPaper Class="surface-card metric-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.TaskAlt" Color="Color.Success" Size="Size.Large" />
                <MudText Typo="Typo.h5">@snapshot.CompletedItems</MudText>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">Completed</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Class="surface-card metric-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.PendingActions" Color="Color.Info" Size="Size.Large" />
                <MudText Typo="Typo.h5">@snapshot.InProgressItems</MudText>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">In progress</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Class="surface-card metric-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.Schedule" Color="Color.Warning" Size="Size.Large" />
                <MudText Typo="Typo.h5">@snapshot.DueThisMonth</MudText>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">Due this month</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Class="surface-card metric-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Error" Size="Size.Large" />
                <MudText Typo="Typo.h5">@snapshot.RapidRampItems</MudText>
                <MudText Typo="Typo.body2" Class="mud-secondary-text">Rapid-ramp ready</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="surface-card mb-4" Elevation="0">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">Current focus</MudText>
                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">Top 5</MudChip>
                </MudStack>
                <MudList T="string">
                    @foreach (var item in snapshot.FocusItems)
                    {
                        <MudListItem T="string" Class="focus-item">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="w-100">
                                <div>
                                    <MudText Typo="Typo.subtitle2">@item.Title</MudText>
                                    <MudText Typo="Typo.body2" Class="mud-secondary-text">@item.Domain • @item.Lane • due @item.TargetDate.ToString("MMM d")</MudText>
                                    @{ var suggestedResources = GetSuggestedResources(item); }
                                    @if (suggestedResources.Count > 0)
                                    {
                                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-2">
                                            @foreach (var resource in suggestedResources)
                                            {
                                                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Href="@resource.Url" Target="_blank" EndIcon="@Icons.Material.Filled.OpenInNew">
                                                    @resource.Title
                                                </MudButton>
                                            }
                                        </MudStack>
                                    }
                                </div>
                                <MudChip T="string" Variant="Variant.Filled" Color="@GetStatusColor(item.Status)">@item.Status</MudChip>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="surface-card mb-4" Elevation="0">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">Upcoming timeline</MudText>
                    <MudText Typo="Typo.caption" Class="mud-secondary-text">Next 6 items</MudText>
                </MudStack>
                @foreach (var item in snapshot.UpcomingItems)
                {
                    <MudPaper Class="timeline-entry mb-3" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <MudText Typo="Typo.subtitle2">@item.Title</MudText>
                                <MudText Typo="Typo.body2" Class="mud-secondary-text">@item.TargetDate.ToString("MMM d, yyyy") • @item.Type • @item.Domain</MudText>
                            </div>
                            <MudChip T="string" Variant="Variant.Filled" Color="@GetStatusColor(item.Status)">@item.Status</MudChip>
                        </MudStack>
                    </MudPaper>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="7">
            <MudPaper Class="surface-card mb-4" Elevation="0">
                <MudText Typo="Typo.h6" Class="mb-3">Pinned resources</MudText>
                <MudGrid>
                    @foreach (var resource in snapshot.PinnedResources)
                    {
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="resource-card" Elevation="0">
                                <MudText Typo="Typo.subtitle2">@resource.Title</MudText>
                                <MudText Typo="Typo.body2" Class="mud-secondary-text mb-2">@resource.Section • @resource.Kind</MudText>
                                <MudText Typo="Typo.body2" Class="mb-3">@resource.Summary</MudText>
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@resource.Url" Target="_blank" EndIcon="@Icons.Material.Filled.OpenInNew">
                                    Open resource
                                </MudButton>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="5">
            <MudPaper Class="surface-card mb-4" Elevation="0">
                <MudText Typo="Typo.h6" Class="mb-3">Recent notes</MudText>
                @foreach (var note in snapshot.RecentNotes)
                {
                    <MudPaper Class="note-card mb-3" Elevation="0">
                        <MudText Typo="Typo.subtitle2">@note.Title</MudText>
                        <MudText Typo="Typo.caption" Class="mud-secondary-text">@note.Category • updated @note.UpdatedUtc.ToLocalTime().ToString("MMM d")</MudText>
                        <MudText Typo="Typo.body2" Class="mt-2">@Truncate(note.Content, 170)</MudText>
                    </MudPaper>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12">
            <MudPaper Class="surface-card mb-4" Elevation="0">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <div>
                        <MudText Typo="Typo.h6">Announcements</MudText>
                        <MudText Typo="Typo.body2" Class="mud-secondary-text">@GetAnnouncementSectionSummary()</MudText>
                    </div>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshAnnouncementsAsync">
                        Refresh
                    </MudButton>
                </MudStack>

                <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Class="mb-4">
                    @foreach (var stream in announcementStreams)
                    {
                        var isSelected = selectedAnnouncementStream == stream;
                        <MudButton Variant="@(isSelected ? Variant.Filled : Variant.Outlined)" OnClick="@(() => SelectAnnouncementStream(stream))">
                            @GetAnnouncementStreamLabel(stream)
                        </MudButton>
                    }
                </MudButtonGroup>

                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" Class="mb-4">
                    <MudSelect T="string" Value="@selectedAnnouncementTopic" ValueChanged="OnAnnouncementTopicChanged" Label="Topic" Variant="Variant.Outlined" Dense="true" Style="min-width: 220px;">
                        @foreach (var topic in ActiveAnnouncementTopics)
                        {
                            <MudSelectItem T="string" Value="@topic">@topic</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="string" Value="@selectedAnnouncementSource" ValueChanged="OnAnnouncementSourceChanged" Label="Source" Variant="Variant.Outlined" Dense="true" Style="min-width: 220px;">
                        @foreach (var source in ActiveAnnouncementSources)
                        {
                            <MudSelectItem T="string" Value="@source">@source</MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>

                @if (isLoadingAnnouncements)
                {
                    <MudSkeleton Height="220px" />
                }
                else if (!string.IsNullOrWhiteSpace(announcementError))
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">@announcementError</MudAlert>
                }
                else if (FilteredAnnouncements.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No items match the current filters for @GetAnnouncementStreamLabel(selectedAnnouncementStream) yet.</MudAlert>
                }
                else
                {
                    @foreach (var announcement in FilteredAnnouncements)
                    {
                        <MudPaper Class="timeline-entry mb-3" Elevation="0">
                            <MudStack Spacing="2">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                    <div>
                                        <MudText Typo="Typo.subtitle1">@announcement.Title</MudText>
                                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-1">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetAnnouncementTopicColor(announcement.Topic)">@announcement.Topic</MudChip>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@announcement.Source</MudChip>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">@GetAnnouncementStreamLabel(announcement.Stream)</MudChip>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@FormatAnnouncementDate(announcement.PublishedUtc)</MudChip>
                                        </MudStack>
                                    </div>
                                    @if (seenAnnouncements.Contains(announcement.Url))
                                    {
                                        <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">Seen</MudChip>
                                    }
                                    else if (IsAnnouncementSaved(announcement))
                                    {
                                        <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">Saved</MudChip>
                                    }
                                </MudStack>

                                @if (!string.IsNullOrWhiteSpace(announcement.Summary))
                                {
                                    <MudText Typo="Typo.body2" Class="mud-secondary-text">@announcement.Summary</MudText>
                                }

                                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@announcement.Url" Target="_blank" EndIcon="@Icons.Material.Filled.OpenInNew">
                                        Open
                                    </MudButton>
                                    <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Visibility" OnClick="@(() => MarkAnnouncementSeen(announcement))">
                                        @(seenAnnouncements.Contains(announcement.Url) ? "Seen" : "Mark as seen")
                                    </MudButton>
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Secondary"
                                               StartIcon="@(IsAnnouncementSaved(announcement) ? Icons.Material.Filled.Check : Icons.Material.Filled.AddLink)"
                                               Disabled="@IsAnnouncementSaved(announcement)"
                                               OnClick="@(() => SaveAnnouncementAsResourceAsync(announcement))">
                                        @(IsAnnouncementSaved(announcement) ? "Saved" : "Save to resources")
                                    </MudButton>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private bool isLoading = true;
    private bool isLoadingAnnouncements = true;
    private UpskillTracker.Models.DashboardSnapshot? snapshot;
    private List<UpskillTracker.Models.ResourceEntry> resources = [];
    private List<UpskillTracker.Models.AnnouncementItem> announcements = [];
    private const int VisibleAnnouncementsPerStream = 8;
    private HashSet<string> seenAnnouncements = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<UpskillTracker.Models.AnnouncementStream> announcementStreams =
    [
        UpskillTracker.Models.AnnouncementStream.MicrosoftOfficial,
        UpskillTracker.Models.AnnouncementStream.IndustryInsights
    ];
    private List<string> announcementTopics = ["All topics"];
    private List<string> announcementSources = ["All sources"];
    private string selectedAnnouncementTopic = "All topics";
    private string selectedAnnouncementSource = "All sources";
    private UpskillTracker.Models.AnnouncementStream selectedAnnouncementStream = UpskillTracker.Models.AnnouncementStream.MicrosoftOfficial;
    private string? announcementError;
    private double completionRate;

    protected override async Task OnInitializedAsync()
    {
        var snapshotTask = TrackerService.GetDashboardSnapshotAsync();
        var resourcesTask = TrackerService.GetResourcesAsync();
        var announcementsTask = LoadAnnouncementsAsync();

        snapshot = await snapshotTask;
        resources = await resourcesTask;
        await announcementsTask;

        completionRate = snapshot is null ? 0 : (double)snapshot.CompletionRate;
        isLoading = false;
    }

    private IReadOnlyList<UpskillTracker.Models.AnnouncementItem> ActiveAnnouncements => announcements
        .Where(item => item.Stream == selectedAnnouncementStream)
        .ToList();

    private IReadOnlyList<string> ActiveAnnouncementTopics => announcementTopics;

    private IReadOnlyList<string> ActiveAnnouncementSources => announcementSources;

    private IReadOnlyList<UpskillTracker.Models.AnnouncementItem> FilteredAnnouncements => ActiveAnnouncements
        .Where(item => selectedAnnouncementTopic == "All topics" || item.Topic.Equals(selectedAnnouncementTopic, StringComparison.OrdinalIgnoreCase))
        .Where(item => selectedAnnouncementSource == "All sources" || item.Source.Equals(selectedAnnouncementSource, StringComparison.OrdinalIgnoreCase))
        .Take(VisibleAnnouncementsPerStream)
        .ToList();

    private IReadOnlyList<UpskillTracker.Models.ResourceEntry> GetSuggestedResources(UpskillTracker.Models.TrainingItem item)
        => TaskResourceMatcher.GetMatches(item, resources, 2);

    private async Task LoadAnnouncementsAsync(bool forceRefresh = false)
    {
        try
        {
            isLoadingAnnouncements = true;
            announcementError = null;
            var items = forceRefresh
                ? await AnnouncementFeedService.RefreshAsync()
                : await AnnouncementFeedService.GetAnnouncementsAsync();

            announcements = items.ToList();
            RebuildAnnouncementFilters();
        }
        catch (Exception)
        {
            announcementError = "The live feed could not be loaded right now. Try refreshing again in a moment.";
        }
        finally
        {
            isLoadingAnnouncements = false;
        }
    }

    private Task OnAnnouncementTopicChanged(string value)
    {
        selectedAnnouncementTopic = value;
        return Task.CompletedTask;
    }

    private Task OnAnnouncementSourceChanged(string value)
    {
        selectedAnnouncementSource = value;
        return Task.CompletedTask;
    }

    private void SelectAnnouncementStream(UpskillTracker.Models.AnnouncementStream stream)
    {
        if (selectedAnnouncementStream == stream)
        {
            return;
        }

        selectedAnnouncementStream = stream;
        RebuildAnnouncementFilters();
    }

    private async Task RefreshAnnouncementsAsync()
    {
        await LoadAnnouncementsAsync(forceRefresh: true);
        Snackbar.Add("Announcement feed refreshed.", Severity.Success);
    }

    private void MarkAnnouncementSeen(UpskillTracker.Models.AnnouncementItem announcement)
    {
        seenAnnouncements.Add(announcement.Url);
    }

    private async Task SaveAnnouncementAsResourceAsync(UpskillTracker.Models.AnnouncementItem announcement)
    {
        if (IsAnnouncementSaved(announcement))
        {
            Snackbar.Add("That link is already in your resource library.", Severity.Info);
            return;
        }

        try
        {
            var nextSortOrder = resources
                .Where(resource => resource.Section.Equals(announcement.Topic, StringComparison.OrdinalIgnoreCase))
                .Select(resource => resource.SortOrder)
                .DefaultIfEmpty(0)
                .Max() + 10;

            var resource = BuildAnnouncementResource(announcement, nextSortOrder);

            await TrackerService.SaveResourceAsync(resource);
            resources = await TrackerService.GetResourcesAsync();
            seenAnnouncements.Add(announcement.Url);
            Snackbar.Add("Announcement saved to resources.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not save this announcement: {ex.Message}", Severity.Error);
        }
    }

    private bool IsAnnouncementSaved(UpskillTracker.Models.AnnouncementItem announcement)
        => resources.Any(resource => resource.Url.Equals(announcement.Url, StringComparison.OrdinalIgnoreCase));

    private UpskillTracker.Models.ResourceEntry BuildAnnouncementResource(UpskillTracker.Models.AnnouncementItem announcement, int sortOrder)
    {
        var tags = string.Join(", ", new[] { "announcement", announcement.Topic, announcement.Source }.Where(value => !string.IsNullOrWhiteSpace(value)));
        var notes = $"Saved from the {GetAnnouncementStreamLabel(announcement.Stream).ToLowerInvariant()} source {announcement.Source} on {DateTime.UtcNow:yyyy-MM-dd}.";

        return new UpskillTracker.Models.ResourceEntry
        {
            Title = TruncateValue(announcement.Title, 140),
            Section = TruncateValue(announcement.Topic, 80),
            Url = TruncateValue(announcement.Url, 500),
            Kind = UpskillTracker.Models.ResourceKind.Documentation,
            Summary = TruncateValue(announcement.Summary, 1500),
            Tags = TruncateValue(tags, 300),
            Notes = TruncateValue(notes, 2000),
            SortOrder = sortOrder
        };
    }

    private static string TruncateValue(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var trimmed = value.Trim();
        return trimmed.Length <= maxLength ? trimmed : trimmed[..maxLength];
    }

    private static Color GetStatusColor(UpskillTracker.Models.TrackerStatus status) => status switch
    {
        UpskillTracker.Models.TrackerStatus.Completed => Color.Success,
        UpskillTracker.Models.TrackerStatus.InProgress => Color.Info,
        UpskillTracker.Models.TrackerStatus.Blocked => Color.Error,
        _ => Color.Default
    };

    private static string Truncate(string value, int length)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= length)
        {
            return value;
        }

        return string.Concat(value[..length], "…");
    }

    private static Color GetAnnouncementTopicColor(string topic) => topic switch
    {
        "Azure AI Foundry" => Color.Primary,
        "GitHub Copilot" => Color.Secondary,
        "Developer Tools" => Color.Info,
        "LLMs" => Color.Secondary,
        "Research" => Color.Success,
        "Industry" => Color.Warning,
        "Agents" => Color.Primary,
        "Azure API Management" => Color.Warning,
        "App Service" => Color.Info,
        _ => Color.Success
    };

    private static string FormatAnnouncementDate(DateTime publishedUtc)
    {
        var now = DateTime.UtcNow;
        var age = now - publishedUtc;

        if (age.TotalDays < 1)
        {
            return age.TotalHours < 1
                ? "Updated recently"
                : $"{Math.Max(1, (int)age.TotalHours)}h ago";
        }

        if (age.TotalDays < 7)
        {
            return $"{Math.Max(1, (int)age.TotalDays)}d ago";
        }

        return publishedUtc.ToLocalTime().ToString("MMM d");
    }

    private string GetDashboardHeadline()
    {
        if (snapshot is null)
        {
            return "Ready";
        }

        if (snapshot.OverdueItems > 0)
        {
            return "Needs attention";
        }

        if (snapshot.InProgressItems > 0)
        {
            return "In motion";
        }

        return "On Track";
    }

    private void RebuildAnnouncementFilters()
    {
        announcementTopics = ["All topics", .. ActiveAnnouncements.Select(item => item.Topic).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(topic => topic)];
        announcementSources = ["All sources", .. ActiveAnnouncements.Select(item => item.Source).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(source => source)];

        if (!announcementTopics.Contains(selectedAnnouncementTopic, StringComparer.OrdinalIgnoreCase))
        {
            selectedAnnouncementTopic = "All topics";
        }

        if (!announcementSources.Contains(selectedAnnouncementSource, StringComparer.OrdinalIgnoreCase))
        {
            selectedAnnouncementSource = "All sources";
        }
    }

    private string GetAnnouncementSectionSummary()
        => selectedAnnouncementStream == UpskillTracker.Models.AnnouncementStream.MicrosoftOfficial
            ? "Official Microsoft updates for Foundry, GitHub Copilot, APIM, App Service, and related Azure changes."
            : "Curated posts from high-signal AI, research, and developer voices across the industry.";

    private static string GetAnnouncementStreamLabel(UpskillTracker.Models.AnnouncementStream stream)
        => stream switch
        {
            UpskillTracker.Models.AnnouncementStream.MicrosoftOfficial => "Microsoft updates",
            UpskillTracker.Models.AnnouncementStream.IndustryInsights => "Thought leaders and industry",
            _ => "Announcements"
        };

    private string GetDashboardSummary()
    {
        if (snapshot is null)
        {
            return "Use the dashboard to review plan status, saved resources, notes, and the latest curated updates.";
        }

        if (snapshot.OverdueItems > 0)
        {
            return $"{snapshot.OverdueItems} overdue, {snapshot.InProgressItems} in progress, and {snapshot.DueThisMonth} due this month. Open the plan when you want to adjust dates or status.";
        }

        return $"{snapshot.InProgressItems} in progress, {snapshot.DueThisMonth} due this month, and {snapshot.CompletedItems} completed so far. Use resources, notes, or Copilot to decide the next step.";
    }
}
