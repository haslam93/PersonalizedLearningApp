@inject UpskillTracker.Services.TrackerService TrackerService

@if (isLoading)
{
    <MudSkeleton Height="82px" />
}
else if (overdueItems.Count > 0)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true" Class="mb-6 reminder-alert">
        <MudText Typo="Typo.subtitle1">@($"{overdueItems.Count} item(s) need attention")</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">
            Your quickest win is to update status, capture a note, or move the target date when project reality changes.
        </MudText>
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
            @foreach (var item in overdueItems.Take(3))
            {
                <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Label="true">
                    @item.Title (@item.TargetDate.ToString("MMM d"))
                </MudChip>
            }
        </MudStack>
    </MudAlert>
}
else
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Dense="true" Class="mb-6 reminder-alert">
        <MudText Typo="Typo.subtitle1">You are on track</MudText>
        <MudText Typo="Typo.body2">No overdue items right now. Use Stretch work or a project-driven lab if you have extra bandwidth.</MudText>
    </MudAlert>
}

@code {
    private bool isLoading = true;
    private List<UpskillTracker.Models.TrainingItem> overdueItems = [];

    protected override async Task OnInitializedAsync()
    {
        overdueItems = await TrackerService.GetOverdueItemsAsync();
        isLoading = false;
    }
}
