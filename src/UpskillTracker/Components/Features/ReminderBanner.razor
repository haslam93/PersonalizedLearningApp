@inject UpskillTracker.Services.TrackerService TrackerService

@if (isLoading)
{
    <MudSkeleton Height="82px" />
}
else if (TrackerService.HasRecentTransientReadFailure)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-6 reminder-alert reminder-alert-warning">
        <MudText Typo="Typo.subtitle1">Database offline</MudText>
        <MudText Typo="Typo.body2">@TrackerService.DatabaseUnavailableMessage</MudText>
    </MudAlert>
}
else if (overdueItems.Count > 0)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true" Class="mb-6 reminder-alert reminder-alert-warning">
        <MudText Typo="Typo.subtitle1">@($"{overdueItems.Count} core commitment{(overdueItems.Count == 1 ? string.Empty : "s")} need attention")</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">
            Start the first item, update its progress, or move the target date if the plan is no longer realistic. Nice-to-have work is excluded from this warning.
        </MudText>
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
            @foreach (var item in overdueItems.Take(3))
            {
                <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Label="true">
                    @item.Title (@item.TargetDate.ToString("MMM d"))
                </MudChip>
            }
        </MudStack>
    </MudAlert>
}
else if (optionalOverdueCount > 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-6 reminder-alert">
        <MudText Typo="Typo.subtitle1">Core plan is on schedule</MudText>
        <MudText Typo="Typo.body2">@optionalOverdueCount nice-to-have item@(optionalOverdueCount == 1 ? " is" : "s are") past its target date. Reschedule it when you intentionally bring it back into focus.</MudText>
    </MudAlert>
}
else
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Dense="true" Class="mb-6 reminder-alert reminder-alert-success">
        <MudText Typo="Typo.subtitle1">On Track</MudText>
        <MudText Typo="Typo.body2">No overdue items right now. Use the dashboard, plan, or Copilot tab to pick the next move.</MudText>
    </MudAlert>
}

@code {
    private bool isLoading = true;
    private List<UpskillTracker.Models.TrainingItem> overdueItems = [];
    private int optionalOverdueCount;

    protected override async Task OnInitializedAsync()
    {
        var allOverdueItems = await TrackerService.GetOverdueItemsAsync();
        overdueItems = allOverdueItems
            .Where(item => !TrainingPlanPrioritizer.IsNiceToHave(item))
            .ToList();
        optionalOverdueCount = allOverdueItems.Count(TrainingPlanPrioritizer.IsNiceToHave);
        isLoading = false;
    }
}
