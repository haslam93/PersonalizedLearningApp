@inject UpskillTracker.Services.TrackerService TrackerService
@inject ISnackbar Snackbar

<div class="section-shell">
    <MudPaper Class="surface-card section-intro-card tools-intro-card mb-4" Elevation="0">
        <MudGrid Style="align-items:center;">
            <MudItem xs="12" md="8">
                <MudText Typo="Typo.overline" Class="text-uppercase section-kicker">My learning tools</MudText>
                <MudText Typo="Typo.h5">One launchpad for the hubs you built</MudText>
                <MudText Typo="Typo.body2" Class="section-summary">
                    Open your Azure, Foundry, and GitHub learning experiences without leaving the portal. Tool sessions are added to Learning History so building and using your own resources counts as progress.
                </MudText>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Href="@UpskillTracker.Services.LearningToolCatalog.DirectoryUrl"
                           Target="_blank"
                           rel="noopener noreferrer"
                           StartIcon="@Icons.Material.Filled.Language"
                           EndIcon="@Icons.Material.Filled.OpenInNew">
                    View public directory
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudGrid Spacing="3" Class="learning-tools-grid">
        @foreach (var tool in UpskillTracker.Services.LearningToolCatalog.Items)
        {
            <MudItem xs="12" md="6">
                <MudPaper Class="@($"learning-tool-card {tool.AccentClass}")" Elevation="0">
                    <MudStack Spacing="2" Class="h-100">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                            <MudAvatar Class="learning-tool-icon" Variant="Variant.Filled">
                                <MudIcon Icon="@tool.Icon" />
                            </MudAvatar>
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@tool.Category</MudChip>
                        </MudStack>
                        <div>
                            <MudText Typo="Typo.h6">@tool.Title</MudText>
                            <MudText Typo="Typo.body2" Class="mud-secondary-text mt-1">@tool.Description</MudText>
                        </div>
                        <MudPaper Class="learning-tool-use-case" Elevation="0">
                            <MudText Typo="Typo.overline">Best for</MudText>
                            <MudText Typo="Typo.body2">@tool.BestFor</MudText>
                        </MudPaper>
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                            @foreach (var topic in tool.Topics)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Default">@topic</MudChip>
                            }
                        </MudStack>
                        <MudButton Class="mt-auto"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.RocketLaunch"
                                   EndIcon="@Icons.Material.Filled.OpenInNew"
                                   Href="@tool.Url"
                                   Target="_blank"
                                   rel="noopener noreferrer"
                                   OnClick="@(() => RecordToolOpenedAsync(tool))">
                            Launch tool
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</div>

@code {
    private async Task RecordToolOpenedAsync(UpskillTracker.Models.LearningTool tool)
    {
        try
        {
            var recorded = await TrackerService.RecordToolOpenedAsync(tool);
            if (!recorded)
            {
                Snackbar.Add("The tool will open, but this launch could not be added to Learning History.", Severity.Warning);
            }
        }
        catch (UpskillTracker.Services.TrackerStorageUnavailableException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }

    }
}
