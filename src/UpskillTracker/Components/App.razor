@using Microsoft.AspNetCore.Components.Authorization

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="UpskillTracker.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <MudThemeProvider Theme="@Theme" />
    <CascadingAuthenticationState>
        <Routes @rendermode="InteractiveServer" />
    </CascadingAuthenticationState>
    <div id="components-reconnect-modal"
         class="components-reconnect-hide reconnect-modal"
         role="dialog"
         aria-modal="true"
         aria-labelledby="components-reconnect-title"
         aria-describedby="components-reconnect-description">
        <div class="reconnect-card">
            <MudIcon Icon="@Icons.Material.Filled.CloudSync" Color="Color.Primary" Size="Size.Large" />
            <h2 id="components-reconnect-title" class="reconnect-title">Restoring your learning portal</h2>
            <p id="components-reconnect-description" class="reconnect-description">
                The Azure connection changed while this page was open. Navigation will resume automatically, or you can reload now.
            </p>
            <button id="components-reconnect-reload" type="button" class="reconnect-button">Reload portal</button>
        </div>
    </div>
    <script src="app.js"></script>
    <script>window.upskillTracker.initializeReconnectRecovery();</script>
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
</body>

</html>

@code {
    public static readonly MudTheme Theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#4f7cff",
            Secondary = "#7c4dff",
            Tertiary = "#0ea5e9",
            Background = "#f4f7fb",
            Surface = "#ffffff",
            DrawerBackground = "#081122",
            DrawerText = "#f4f7fb",
            AppbarBackground = "rgba(8, 17, 34, 0.92)",
            AppbarText = "#ffffff"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "18px"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Segoe UI", "Inter", "Arial", "sans-serif"]
            }
        }
    };
}
