@inherits LayoutComponentBase

<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="tracker-appbar">
        <MudAvatar Color="Color.Primary" Class="tracker-app-icon">
            <MudIcon Icon="@Icons.Material.Filled.School" />
        </MudAvatar>
        <MudStack Spacing="0" Class="ml-2">
            <MudText Typo="Typo.h6">Azure AI Upskilling Hub</MudText>
            <MudText Typo="Typo.caption" Class="mud-secondary-text">Private learning workspace</MudText>
        </MudStack>
        <MudSpacer />
    </MudAppBar>

    <MudMainContent>
        <PinGate>
            <div class="shell-container">
                @Body
            </div>
        </PinGate>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
