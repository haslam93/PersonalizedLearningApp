@inherits LayoutComponentBase
@inject UpskillTracker.Services.DatabaseAvailabilityState DatabaseAvailabilityState

<MudPopoverProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="tracker-appbar">
        <MudAvatar Color="Color.Primary" Class="tracker-app-icon">
            <MudIcon Icon="@Icons.Material.Filled.School" />
        </MudAvatar>
        <MudStack Spacing="0" Class="ml-2">
            <MudText Typo="Typo.h6">Hammad's Learning Portal</MudText>
            <MudText Typo="Typo.caption" Class="mud-secondary-text">Focused learning workspace</MudText>
        </MudStack>
        <MudSpacer />
    </MudAppBar>

    <MudMainContent>
        <PinGate>
            <div class="shell-container">
                @if (DatabaseAvailabilityState.IsUnavailable)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mb-4 database-status-banner">
                        <MudText Typo="Typo.subtitle2">Database offline</MudText>
                        <MudText Typo="Typo.body2">@DatabaseAvailabilityState.UserMessage</MudText>
                    </MudAlert>
                }

                @Body
            </div>
        </PinGate>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
