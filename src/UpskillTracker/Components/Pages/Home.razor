@page "/"
@inject UpskillTracker.Services.TrackerService TrackerService

<PageTitle>Hammad's Learning Portal</PageTitle>

<ReminderBanner />

@if (isLoading)
{
	<MudSkeleton Height="210px" Class="mb-6" />
}
else if (snapshot is not null)
{
	<MudPaper Class="hero-card workspace-overview mb-6" Elevation="0">
		<MudGrid Style="align-items:center;">
			<MudItem xs="12" md="7">
				<MudStack Spacing="2">
					<div>
						<MudText Typo="Typo.overline" Class="text-uppercase overview-kicker">Workspace overview</MudText>
						<MudText Typo="Typo.h3" Class="mb-2">Hammad's Learning Portal</MudText>
						<MudText Typo="Typo.body1" Class="overview-summary">@GetOverviewSummary()</MudText>
					</div>

					<MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
						<MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Icon="@Icons.Material.Filled.TaskAlt">@snapshot.CompletedItems completed</MudChip>
						<MudChip T="string" Color="Color.Info" Variant="Variant.Filled" Icon="@Icons.Material.Filled.PendingActions">@snapshot.InProgressItems in progress</MudChip>
						<MudChip T="string" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Schedule">@snapshot.DueThisMonth due this month</MudChip>
					</MudStack>
				</MudStack>
			</MudItem>
			<MudItem xs="12" md="5">
				<div class="overview-stats-grid">
					<MudPaper Class="overview-stat" Elevation="0">
						<MudText Typo="Typo.caption" Class="mud-secondary-text">Completion</MudText>
						<MudText Typo="Typo.h4">@snapshot.CompletionRate%</MudText>
					</MudPaper>
					<MudPaper Class="overview-stat" Elevation="0">
						<MudText Typo="Typo.caption" Class="mud-secondary-text">Pinned resources</MudText>
						<MudText Typo="Typo.h4">@snapshot.PinnedResources.Count</MudText>
					</MudPaper>
					<MudPaper Class="overview-stat" Elevation="0">
						<MudText Typo="Typo.caption" Class="mud-secondary-text">Recent notes</MudText>
						<MudText Typo="Typo.h4">@snapshot.RecentNotes.Count</MudText>
					</MudPaper>
					<MudPaper Class="overview-stat" Elevation="0">
						<MudText Typo="Typo.caption" Class="mud-secondary-text">Needs attention</MudText>
						<MudText Typo="Typo.h4">@snapshot.OverdueItems</MudText>
					</MudPaper>
				</div>
			</MudItem>
		</MudGrid>
	</MudPaper>
}

<MudTabs Elevation="0" Rounded="true" PanelClass="pt-6">
	<MudTabPanel Text="Dashboard" Icon="@Icons.Material.Filled.Dashboard">
		<DashboardView />
	</MudTabPanel>
	<MudTabPanel Text="Plan" Icon="@Icons.Material.Filled.Checklist">
		<TrainingPlannerView />
	</MudTabPanel>
	<MudTabPanel Text="Timeline" Icon="@Icons.Material.Filled.Timeline">
		<TimelineView />
	</MudTabPanel>
	<MudTabPanel Text="Resources" Icon="@Icons.Material.Filled.LibraryBooks">
		<ResourcesView />
	</MudTabPanel>
	<MudTabPanel Text="Notes" Icon="@Icons.Material.Filled.StickyNote2">
		<NotesView />
	</MudTabPanel>
	<MudTabPanel Text="Copilot" Icon="@Icons.Material.Filled.SmartToy">
		<CopilotChatView />
	</MudTabPanel>
</MudTabs>

@code {
	private UpskillTracker.Models.DashboardSnapshot? snapshot;
	private bool isLoading = true;

	protected override async Task OnInitializedAsync()
	{
		snapshot = await TrackerService.GetDashboardSnapshotAsync();
		isLoading = false;
	}

	private string GetOverviewSummary()
	{
		if (snapshot is null)
		{
			return "Your learning plan, notes, resources, and Copilot workspace live together here.";
		}

		if (snapshot.OverdueItems > 0)
		{
			return $"{snapshot.OverdueItems} item{(snapshot.OverdueItems == 1 ? string.Empty : "s")} need attention, {snapshot.InProgressItems} are already in progress, and {snapshot.DueThisMonth} are due this month.";
		}

		return $"No overdue items right now. {snapshot.InProgressItems} item{(snapshot.InProgressItems == 1 ? string.Empty : "s")} are in progress, and {snapshot.DueThisMonth} are due this month.";
	}
}
