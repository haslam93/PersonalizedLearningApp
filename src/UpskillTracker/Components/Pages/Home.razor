@page "/"
@inject UpskillTracker.Services.TrackerService TrackerService

<PageTitle>Hammad's Learning Portal</PageTitle>

<ReminderBanner />

@if (TrackerService.HasRecentTransientReadFailure)
{
	<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-4">
		@TrackerService.DatabaseUnavailableMessage
	</MudAlert>
}

@if (isLoading)
{
	<MudSkeleton Height="210px" Class="mb-6" />
}
else if (snapshot is not null)
{
	<MudPaper Class="hero-card workspace-overview mb-6" Elevation="0">
		<MudGrid Style="align-items:center;">
			<MudItem xs="12" md="7">
				<MudStack Spacing="2">
					<div>
						<MudText Typo="Typo.overline" Class="text-uppercase overview-kicker">Workspace overview</MudText>
						<MudText Typo="Typo.h3" Class="mb-2">Hammad's Learning Portal</MudText>
						<MudText Typo="Typo.body1" Class="overview-summary">@GetOverviewSummary()</MudText>
					</div>

					<MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
						<MudChip T="string" Color="@(snapshot.AtRiskItems > 0 ? Color.Error : Color.Success)" Variant="Variant.Filled" Icon="@Icons.Material.Filled.PriorityHigh">@snapshot.AtRiskItems at risk</MudChip>
						<MudChip T="string" Color="Color.Info" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Checklist">@snapshot.CoreRemainingItems core commitments</MudChip>
						<MudChip T="string" Color="Color.Secondary" Variant="Variant.Filled" Icon="@Icons.Material.Filled.WorkspacePremium">@snapshot.CertificationGoals certification goals</MudChip>
					</MudStack>
				</MudStack>
			</MudItem>
			<MudItem xs="12" md="5">
				<div class="overview-stats-grid">
					<MudPaper Class="overview-stat" Elevation="0">
						<MudText Typo="Typo.caption" Class="mud-secondary-text">Core completion</MudText>
						<MudText Typo="Typo.h4">@snapshot.CommitmentCompletionRate%</MudText>
					</MudPaper>
					<MudPaper Class="overview-stat" Elevation="0">
						<MudText Typo="Typo.caption" Class="mud-secondary-text">Due in 14 days</MudText>
						<MudText Typo="Typo.h4">@snapshot.DueNext14Days</MudText>
					</MudPaper>
					<MudPaper Class="overview-stat" Elevation="0">
						<MudText Typo="Typo.caption" Class="mud-secondary-text">At risk</MudText>
						<MudText Typo="Typo.h4">@snapshot.AtRiskItems</MudText>
					</MudPaper>
					<MudPaper Class="overview-stat" Elevation="0">
						<MudText Typo="Typo.caption" Class="mud-secondary-text">Nice to have</MudText>
						<MudText Typo="Typo.h4">@snapshot.NiceToHaveItems</MudText>
					</MudPaper>
				</div>
			</MudItem>
		</MudGrid>
	</MudPaper>
}

<MudTabs Elevation="0" Rounded="true" PanelClass="pt-6" Class="tracker-tabs">
	<MudTabPanel Text="Dashboard" Icon="@Icons.Material.Filled.Dashboard">
		<DashboardView />
	</MudTabPanel>
	<MudTabPanel Text="Plan" Icon="@Icons.Material.Filled.Checklist">
		<TrainingPlannerView />
	</MudTabPanel>
	<MudTabPanel Text="Certifications" Icon="@Icons.Material.Filled.WorkspacePremium">
		<CertificationsView />
	</MudTabPanel>
	<MudTabPanel Text="Timeline" Icon="@Icons.Material.Filled.Timeline">
		<TimelineView />
	</MudTabPanel>
	<MudTabPanel Text="Resources" Icon="@Icons.Material.Filled.LibraryBooks">
		<ResourcesView />
	</MudTabPanel>
	<MudTabPanel Text="Videos" Icon="@Icons.Material.Filled.OndemandVideo">
		<VideosView />
	</MudTabPanel>
	<MudTabPanel Text="Notes" Icon="@Icons.Material.Filled.StickyNote2">
		<NotesView />
	</MudTabPanel>
	<MudTabPanel Text="Copilot" Icon="@Icons.Material.Filled.SmartToy">
		<CopilotChatView />
	</MudTabPanel>
</MudTabs>

@code {
	private UpskillTracker.Models.DashboardSnapshot? snapshot;
	private bool isLoading = true;

	protected override async Task OnInitializedAsync()
	{
		snapshot = await TrackerService.GetDashboardSnapshotAsync();
		isLoading = false;
	}

	private string GetOverviewSummary()
	{
		if (TrackerService.HasRecentTransientReadFailure)
		{
			return "The PostgreSQL database is currently down or stopped. Start it in Azure and refresh this page when it is back online.";
		}

		if (snapshot is null)
		{
			return "Your learning plan, notes, resources, and Copilot workspace live together here.";
		}

		if (snapshot.AtRiskItems > 0)
		{
			var nextItem = snapshot.FocusItems.FirstOrDefault()?.Title;
			return nextItem is null
				? $"{snapshot.AtRiskItems} core item{(snapshot.AtRiskItems == 1 ? string.Empty : "s")} need attention. Review dates and reduce the nice-to-have backlog."
				: $"{FormatItemCount(snapshot.AtRiskItems)} at risk. Start with \"{nextItem}\" and keep nice-to-have work behind core commitments.";
		}

		return $"The committed plan is on schedule. {FormatInProgressItems(snapshot.InProgressItems)}, {snapshot.DueNext14Days} are due in the next 14 days, and {snapshot.NiceToHaveItems} are optional.";
	}

	private static string FormatInProgressItems(int count)
		=> $"{count} item{(count == 1 ? string.Empty : "s")} {(count == 1 ? "is" : "are")} in progress";

	private static string FormatItemCount(int count)
		=> $"{count} item{(count == 1 ? " is" : "s are")}";
}
