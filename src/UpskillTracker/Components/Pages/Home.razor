@page "/"

<PageTitle>Azure AI Upskilling Hub</PageTitle>

<ReminderBanner />

<MudPaper Class="hero-card mb-6" Elevation="0">
	<MudGrid>
		<MudItem xs="12" md="8">
			<MudText Typo="Typo.h3" Class="mb-2">Track the Azure AI plan you actually want to follow</MudText>
			<MudText Typo="Typo.body1" Class="mud-secondary-text mb-4">
				This tracker blends your learning plan, project-driven pivots, curated Microsoft resources, notes, and evidence in one place.
			</MudText>
			<MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
				<MudChip T="string" Color="Color.Primary" Variant="Variant.Filled">Core lane</MudChip>
				<MudChip T="string" Color="Color.Info" Variant="Variant.Filled">Stretch lane</MudChip>
				<MudChip T="string" Color="Color.Error" Variant="Variant.Filled">Rapid-ramp lane</MudChip>
			</MudStack>
		</MudItem>
		<MudItem xs="12" md="4">
			<MudPaper Class="surface-card glass-panel" Elevation="0">
				<MudText Typo="Typo.subtitle1">Included focus areas</MudText>
				<MudList T="string" Dense="true" Class="mt-2">
					<MudListItem T="string">Microsoft Foundry and current SDK patterns</MudListItem>
					<MudListItem T="string">Azure AI Search and RAG design</MudListItem>
					<MudListItem T="string">App Service, Container Apps, APIM, and integration services</MudListItem>
					<MudListItem T="string">Microsoft Agent Framework and Azure SRE Agent</MudListItem>
				</MudList>
			</MudPaper>
		</MudItem>
	</MudGrid>
</MudPaper>

<MudTabs Elevation="0" Rounded="true" PanelClass="pt-6">
	<MudTabPanel Text="Dashboard" Icon="@Icons.Material.Filled.Dashboard">
		<DashboardView />
	</MudTabPanel>
	<MudTabPanel Text="Plan" Icon="@Icons.Material.Filled.Checklist">
		<TrainingPlannerView />
	</MudTabPanel>
	<MudTabPanel Text="Timeline" Icon="@Icons.Material.Filled.Timeline">
		<TimelineView />
	</MudTabPanel>
	<MudTabPanel Text="Resources" Icon="@Icons.Material.Filled.LibraryBooks">
		<ResourcesView />
	</MudTabPanel>
	<MudTabPanel Text="Notes" Icon="@Icons.Material.Filled.StickyNote2">
		<NotesView />
	</MudTabPanel>
	<MudTabPanel Text="Copilot" Icon="@Icons.Material.Filled.SmartToy">
		<CopilotChatView />
	</MudTabPanel>
</MudTabs>
