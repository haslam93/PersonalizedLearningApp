@page "/"
@inject UpskillTracker.Services.TrackerService TrackerService

<PageTitle>Hammad's Learning Portal</PageTitle>

<ReminderBanner OnOpenPlan="NavigateToPlanAsync" />

@if (TrackerService.HasRecentTransientReadFailure)
{
	<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-4">
		@TrackerService.DatabaseUnavailableMessage
	</MudAlert>
}

@if (isLoading)
{
	<MudSkeleton Height="210px" Class="mb-6" />
}
else if (snapshot is not null)
{
	<MudPaper Class="hero-card workspace-overview mb-6" Elevation="0">
		<MudGrid Style="align-items:center;">
			<MudItem xs="12" md="7">
				<MudStack Spacing="2">
					<div>
						<MudText Typo="Typo.overline" Class="text-uppercase overview-kicker">Workspace overview</MudText>
						<MudText Typo="Typo.h3" Class="mb-2">Hammad's Learning Portal</MudText>
						<MudText Typo="Typo.body1" Class="overview-summary">@GetOverviewSummary()</MudText>
					</div>

					<MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
						<MudButton Class="overview-action-pill" Color="@(snapshot.AtRiskItems > 0 ? Color.Error : Color.Success)" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PriorityHigh" OnClick="@(() => NavigateToPlanAsync(new UpskillTracker.Models.PlanNavigationRequest("At risk")))">
							@snapshot.AtRiskItems at risk
						</MudButton>
						<MudButton Class="overview-action-pill" Color="Color.Info" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Checklist" OnClick="@(() => NavigateToPlanAsync(new UpskillTracker.Models.PlanNavigationRequest("Core commitments")))">
							@snapshot.CoreRemainingItems core commitments
						</MudButton>
						<MudButton Class="overview-action-pill" Color="Color.Secondary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.WorkspacePremium" OnClick="NavigateToCertifications">
							@snapshot.CertificationGoals certification goals
						</MudButton>
					</MudStack>
				</MudStack>
			</MudItem>
			<MudItem xs="12" md="5">
				<div class="overview-stats-grid">
					<button type="button" class="overview-stat overview-stat-button" @onclick="NavigateToHistory" aria-label="Open learning history">
						<span class="overview-stat-label">Core completion</span>
						<strong class="overview-stat-value">@snapshot.CommitmentCompletionRate%</strong>
						<span class="overview-stat-action">View history</span>
					</button>
					<button type="button" class="overview-stat overview-stat-button" @onclick="@(() => NavigateToPlanAsync(new UpskillTracker.Models.PlanNavigationRequest("Due soon")))" aria-label="Open items due in the next 14 days">
						<span class="overview-stat-label">Due in 14 days</span>
						<strong class="overview-stat-value">@snapshot.DueNext14Days</strong>
						<span class="overview-stat-action">Review due work</span>
					</button>
					<button type="button" class="overview-stat overview-stat-button" @onclick="@(() => NavigateToPlanAsync(new UpskillTracker.Models.PlanNavigationRequest("At risk")))" aria-label="Open at-risk items">
						<span class="overview-stat-label">At risk</span>
						<strong class="overview-stat-value">@snapshot.AtRiskItems</strong>
						<span class="overview-stat-action">Recover plan</span>
					</button>
					<button type="button" class="overview-stat overview-stat-button" @onclick="@(() => NavigateToPlanAsync(new UpskillTracker.Models.PlanNavigationRequest("Nice to have")))" aria-label="Open nice-to-have items">
						<span class="overview-stat-label">Nice to have</span>
						<strong class="overview-stat-value">@snapshot.NiceToHaveItems</strong>
						<span class="overview-stat-action">Review optional work</span>
					</button>
				</div>
			</MudItem>
		</MudGrid>
	</MudPaper>
}

<MudTabs @bind-ActivePanelIndex="activeTabIndex" Elevation="0" Rounded="true" PanelClass="pt-6" Class="tracker-tabs">
	<MudTabPanel Text="Dashboard" Icon="@Icons.Material.Filled.Dashboard">
		<DashboardView OnOpenPlan="NavigateToPlanAsync" OnOpenHistory="NavigateToHistoryAsync" OnOpenHistoryDate="NavigateToHistoryDateAsync" />
	</MudTabPanel>
	<MudTabPanel Text="Plan" Icon="@Icons.Material.Filled.Checklist">
		<TrainingPlannerView NavigationRequest="@planNavigationRequest" NavigationRequestId="@planNavigationToken" />
	</MudTabPanel>
	<MudTabPanel Text="Certifications" Icon="@Icons.Material.Filled.WorkspacePremium">
		<CertificationsView />
	</MudTabPanel>
	<MudTabPanel Text="Timeline" Icon="@Icons.Material.Filled.Timeline">
		<TimelineView OnOpenPlan="NavigateToPlanAsync" />
	</MudTabPanel>
	<MudTabPanel Text="History" Icon="@Icons.Material.Filled.AutoGraph">
		<LearningHistoryView RequestedDate="@historyRequestedDate" NavigationRequestId="@historyNavigationToken" />
	</MudTabPanel>
	<MudTabPanel Text="My Tools" Icon="@Icons.Material.Filled.BuildCircle">
		<LearningToolsView />
	</MudTabPanel>
	<MudTabPanel Text="Resources" Icon="@Icons.Material.Filled.LibraryBooks">
		<ResourcesView />
	</MudTabPanel>
	<MudTabPanel Text="Videos" Icon="@Icons.Material.Filled.OndemandVideo">
		<VideosView />
	</MudTabPanel>
	<MudTabPanel Text="Notes" Icon="@Icons.Material.Filled.StickyNote2">
		<NotesView />
	</MudTabPanel>
	<MudTabPanel Text="Copilot" Icon="@Icons.Material.Filled.SmartToy">
		<CopilotChatView />
	</MudTabPanel>
</MudTabs>

@code {
	private UpskillTracker.Models.DashboardSnapshot? snapshot;
	private bool isLoading = true;
	private int activeTabIndex;
	private int planNavigationToken;
	private int historyNavigationToken;
	private DateTime? historyRequestedDate;
	private UpskillTracker.Models.PlanNavigationRequest planNavigationRequest = new("Do next");

	protected override async Task OnInitializedAsync()
	{
		snapshot = await TrackerService.GetDashboardSnapshotAsync();
		isLoading = false;
	}

	private string GetOverviewSummary()
	{
		if (TrackerService.HasRecentTransientReadFailure)
		{
			return "The PostgreSQL database is currently down or stopped. Start it in Azure and refresh this page when it is back online.";
		}

		if (snapshot is null)
		{
			return "Your learning plan, notes, resources, and Copilot workspace live together here.";
		}

		if (snapshot.AtRiskItems > 0)
		{
			var nextItem = snapshot.FocusItems.FirstOrDefault()?.Title;
			return nextItem is null
				? $"{snapshot.AtRiskItems} core item{(snapshot.AtRiskItems == 1 ? string.Empty : "s")} need attention. Review dates and reduce the nice-to-have backlog."
				: $"{FormatItemCount(snapshot.AtRiskItems)} at risk. Start with \"{nextItem}\" and keep nice-to-have work behind core commitments.";
		}

		return $"The committed plan is on schedule. {FormatInProgressItems(snapshot.InProgressItems)}, {snapshot.DueNext14Days} are due in the next 14 days, and {snapshot.NiceToHaveItems} are optional.";
	}

	private static string FormatInProgressItems(int count)
		=> $"{count} item{(count == 1 ? string.Empty : "s")} {(count == 1 ? "is" : "are")} in progress";

	private static string FormatItemCount(int count)
		=> $"{count} item{(count == 1 ? " is" : "s are")}";

	private Task NavigateToPlanAsync(UpskillTracker.Models.PlanNavigationRequest request)
	{
		planNavigationRequest = request;
		planNavigationToken++;
		activeTabIndex = 1;
		return Task.CompletedTask;
	}

	private void NavigateToCertifications()
		=> activeTabIndex = 2;

	private void NavigateToHistory()
	{
		historyRequestedDate = null;
		historyNavigationToken++;
		activeTabIndex = 4;
	}

	private Task NavigateToHistoryAsync()
	{
		NavigateToHistory();
		return Task.CompletedTask;
	}

	private Task NavigateToHistoryDateAsync(DateTime date)
	{
		historyRequestedDate = date.Date;
		historyNavigationToken++;
		activeTabIndex = 4;
		return Task.CompletedTask;
	}
}
