{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Learning Radar",
  "description": "Curated learning items proposed by the weekly learning radar agentic workflow. Items are imported into the UpskillTracker TrainingItems table at startup, deduplicated by title.",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "domain", "description", "targetDate", "link"],
        "properties": {
          "title": { "type": "string", "maxLength": 140, "description": "Unique title; used for deduplication." },
          "domain": { "type": "string", "maxLength": 80, "description": "Learning domain, e.g. 'Microsoft Foundry', 'GitHub Copilot'." },
          "category": { "type": "string", "maxLength": 80 },
          "description": { "type": "string", "maxLength": 1500 },
          "targetDate": { "type": "string", "format": "date", "description": "Suggested completion date (yyyy-MM-dd)." },
          "lane": { "type": "string", "enum": ["Core", "Stretch", "RapidRamp"], "default": "Stretch" },
          "type": { "type": "string", "enum": ["Learning", "Lab", "Project", "Capstone"], "default": "Learning" },
          "estimatedHours": { "type": "number", "minimum": 0.5, "maximum": 40, "default": 2 },
          "priority": { "type": "integer", "minimum": 1, "maximum": 5, "default": 3 },
          "link": { "type": "string", "format": "uri", "description": "Primary announcement or docs link." },
          "source": { "type": "string", "description": "Where the item was discovered, e.g. 'GitHub Changelog'." },
          "notes": { "type": "string", "maxLength": 3000 },
          "addedOn": { "type": "string", "format": "date", "description": "Date the radar proposed this item." }
        }
      }
    }
  }
}
